-align: left; }\n  }\n  @media (max-width: 720px) {\n    .sol-feat { grid-template-columns: 40px 1fr; gap: 14px; padding: 18px 0; }\n    .sol-feat .n { width: 36px; height: 36px; font-size: 11px; }\n    .sol-feat h4 { font-size: 17px; }\n    .sol-feat:hover { padding-left: 0; }\n    .sol-feat::before { display: none; }\n  }\n  .sol-diffs-row {\n    display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px;\n    margin-top: 72px;\n  }\n  .sol-diff {\n    background: #fff; border: 1px solid var(--bg3); border-radius: 22px;\n    padding: 26px 24px; position: relative; overflow: hidden;\n    display: flex; flex-direction: column;\n    transition: transform .4s cubic-bezier(0.2, 0.8, 0.2, 1),\n                border-color .3s var(--ease),\n                box-shadow .4s var(--ease);\n    will-change: transform;\n  }\n  .sol-diff::before {\n    content: \"\"; position: absolute; inset: 0;\n    border-radius: inherit;\n    background: linear-gradient(180deg, rgba(0,196,122,0.04), rgba(0,153,184,0.02));\n    opacity: 0; transition: opacity .35s var(--ease);\n    pointer-events: none;\n  }\n  .sol-diff > * { position: relative; z-index: 1; }\n  .sol-diff:hover {\n    border-color: rgba(0,196,122,0.4);\n    transform: translateY(-8px) scale(1.02);\n    box-shadow: 0 28px 60px -16px rgba(0,196,122,0.20),\n                0 8px 24px -8px rgba(0,196,122,0.10),\n                0 0 0 1px rgba(0,196,122,0.18) inset;\n  }\n  .sol-diff:hover::before { opacity: 1; }\n  .sol-diff:hover .sd-vis { transform: translateY(-3px); }\n\n  .sd-vis {\n    height: 200px; border-radius: 16px;\n    background: linear-gradient(180deg, var(--bg2) 0%, #fff 100%);\n    border: 1px solid var(--bg3);\n    padding: 18px; margin-bottom: 22px;\n    position: relative; overflow: hidden;\n    transition: transform .4s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow .35s var(--ease);\n    box-shadow: 0 1px 0 rgba(255,255,255,0.6) inset;\n  }\n  .sol-diff:hover .sd-vis { box-shadow: 0 12px 28px -10px rgba(0,196,122,0.18), 0 1px 0 rgba(255,255,255,0.8) inset; }\n  .sol-diff h3 {\n    font-size: 18px; letter-spacing: -0.4px; line-height: 1.25;\n    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;\n    margin-bottom: 10px;\n  }\n  .sol-diff p { font-size: 14px; line-height: 1.55; color: var(--text2); }\n  .new-pill {\n    display: inline-block; padding: 3px 10px; border-radius: 99px;\n    background: var(--grad); color: #fff;\n    font-size: 10px; font-weight: 800; letter-spacing: 0.1em;\n  }\n\n  /* === Visual 1: Anamnese (mini checklist) === */\n  .sd-form {\n    display: flex; flex-direction: column; gap: 8px; height: 100%;\n  }\n  .sd-form .pg-h {\n    display: flex; justify-content: space-between; align-items: center;\n    font-size: 10px; font-weight: 800; color: var(--text3);\n    text-transform: uppercase; letter-spacing: 0.12em;\n  }\n  .sd-form .pg-h .ct {\n    background: rgba(0,196,122,0.12); color: var(--green);\n    padding: 2px 8px; border-radius: 99px;\n    font-size: 9px; font-weight: 800;\n  }\n  .sd-form .pg { height: 4px; background: var(--bg3); border-radius: 99px; overflow: hidden; }\n  .sd-form .pg i { display: block; height: 100%; width: 100%; background: var(--grad); border-radius: 99px; box-shadow: 0 0 12px rgba(0,196,122,0.4); }\n  .sd-form .row {\n    background: #fff; border: 1px solid var(--bg3); border-radius: 9px;\n    padding: 9px 12px; font-size: 12px; font-weight: 700; color: var(--text1);\n    display: flex; justify-content: space-between; align-items: center;\n    flex: 1;\n    box-shadow: 0 1px 2px rgba(0,0,0,0.02);\n  }\n  .sd-form .row .ck {\n    color: #fff; background: var(--grad);\n    width: 18px; height: 18px; border-radius: 50%;\n    display: inline-flex; align-items: center; justify-content: center;\n    font-size: 10px; font-weight: 800;\n    box-shadow: 0 4px 10px rgba(0,196,122,0.30);\n  }\n\n  /* === Visual 2: One Minute Summary === */\n  .sd-audio {\n    background: linear-gradient(155deg, #1A1E26 0%, #0D0F14 100%);\n    border: 1px solid rgba(255,255,255,0.06);\n    color: #fff;\n    height: 100%; padding: 16px 18px;\n    display: flex; flex-direction: column; justify-content: space-between;\n    position: relative; overflow: hidden;\n  }\n  .sd-audio::before {\n    content: \"\"; position: absolute; top: 0; left: 0; right: 0; height: 2px;\n    background: var(--grad);\n  }\n  .sd-audio::after {\n    content: \"\"; position: absolute; right: -40px; bottom: -40px;\n    width: 160px; height: 160px; border-radius: 50%;\n    background: radial-gradient(closest-side, rgba(0,196,122,0.28), transparent 70%);\n    filter: blur(6px);\n  }\n  .sd-audio .h {\n    display: flex; justify-content: space-between; align-items: center;\n    font-size: 10px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase;\n    position: relative; z-index: 1;\n  }\n  .sd-audio .h .l { display: inline-flex; align-items: center; gap: 8px; color: var(--green); }\n  .sd-audio .h .l::before {\n    content: \"\"; width: 7px; height: 7px; border-radius: 50%; background: var(--green);\n    animation: pulse 2s infinite;\n    box-shadow: 0 0 8px var(--green);\n  }\n  .sd-audio .h .r { color: rgba(255,255,255,0.6); font-family: var(--font-mono); letter-spacing: 0; font-size: 11px; }\n  .sd-audio .wbox {\n    display: flex; align-items: center; gap: 14px; position: relative; z-index: 1;\n  }\n  .sd-audio .play {\n    width: 46px; height: 46px; border-radius: 50%;\n    background: var(--grad); color: #fff;\n    display: inline-flex; align-items: center; justify-content: center;\n    font-size: 15px; flex-shrink: 0;\n    box-shadow: 0 0 28px rgba(0,196,122,0.6), 0 4px 12px rgba(0,0,0,0.3);\n    transition: transform .25s var(--ease);\n  }\n  .sol-diff:hover .sd-audio .play { transform: scale(1.06); }\n  .sd-audio .bars { display: flex; align-items: center; gap: 2.5px; height: 44px; flex: 1; }\n  .sd-audio .bars i { display: block; width: 2.5px; border-radius: 2px; background: var(--green); }\n  .sd-audio .bars i.off { background: rgba(255,255,255,0.18); }\n\n  /* === Visual 3: Histórico sempre acessível === */\n  .sd-docs {\n    height: 100%; position: relative;\n    display: flex; align-items: center; justify-content: center;\n  }\n  .sd-doc {\n    position: absolute;\n    background: #fff; border: 1px solid var(--bg3); border-radius: 10px;\n    padding: 10px 12px; box-shadow: 0 10px 24px -6px rgba(0,0,0,0.10);\n    font-size: 10px; font-weight: 700; color: var(--text1);\n    display: flex; align-items: center; gap: 8px;\n    width: 150px;\n    transition: transform .4s cubic-bezier(0.2, 0.8, 0.2, 1);\n  }\n  .sd-doc .ic {\n    width: 28px; height: 28px; border-radius: 7px;\n    background: var(--bg2); color: var(--text3);\n    font-family: var(--font-mono); font-size: 9px; font-weight: 800;\n    display: inline-flex; align-items: center; justify-content: center;\n    flex-shrink: 0;\n  }\n  .sd-doc .m { font-size: 9px; color: var(--text3); font-weight: 600; margin-top: 2px; }\n  .sd-doc.d1 { top: 4px;  left: 4px;  transform: rotate(-8deg); z-index: 1; }\n  .sd-doc.d3 { top: 4px; right: 4px; transform: rotate(8deg); z-index: 1; }\n  .sd-doc.d2 {\n    top: 38px; left: 50%; transform: translateX(-50%) rotate(0);\n    z-index: 2;\n    border-color: rgba(0,196,122,0.40);\n    box-shadow: 0 20px 36px -10px rgba(0,196,122,0.30), 0 0 0 1px rgba(0,196,122,0.15) inset;\n  }\n  .sol-diff:hover .sd-doc.d1 { transform: rotate(-3deg) translate(-4px, -3px); }\n  .sol-diff:hover .sd-doc.d3 { transform: rotate(3deg) translate(4px, -3px); }\n  .sol-diff:hover .sd-doc.d2 { transform: translateX(-50%) translateY(-2px) scale(1.03); }\n\n  .sd-docs .center-pill {\n    position: absolute; bottom: 6px; left: 50%; transform: translateX(-50%);\n    background: var(--grad); color: #fff;\n    padding: 6px 14px; border-radius: 99px;\n    font-size: 10px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase;\n    box-shadow: 0 10px 24px rgba(0,196,122,0.35);\n    display: inline-flex; align-items: center; gap: 8px;\n    white-space: nowrap;\n  }\n  .sd-docs .center-pill::before {\n    content: \"✓\"; font-size: 11px;\n    background: rgba(255,255,255,0.25); width: 16px; height: 16px;\n    border-radius: 50%; display: inline-flex; align-items: center; justify-content: center;\n  }\n\n  /* === Visual 4: Exporta pro prontuário === */\n  .sd-export {\n    height: 100%; display: grid; grid-template-columns: 1fr 44px 1fr;\n    align-items: center; gap: 8px; position: relative;\n  }\n  .sd-box {\n    background: #fff; border: 1px solid var(--bg3); border-radius: 12px;\n    padding: 16px 8px; text-align: center;\n    box-shadow: 0 6px 14px -6px rgba(0,0,0,0.08);\n  }\n  .sd-box .b-logo {\n    font-weight: 800; font-size: 17px; letter-spacing: -0.4px;\n    display: inline-flex; align-items: center; justify-content: center;\n  }\n  .sd-box .b-logo .pill { background: var(--grad); color: #fff; padding: 0 5px 1px; border-radius: 4px; margin-left: 2px; font-size: 14px; }\n  .sd-box .b-icon {\n    width: 44px; height: 44px; border-radius: 10px;\n    background: var(--bg2); border: 1px solid var(--bg3);\n    color: var(--text2); font-family: var(--font-mono); font-size: 14px; font-weight: 800;\n    display: inline-flex; align-items: center; justify-content: center;\n    margin: 0 auto 6px;\n  }\n  .sd-box .b-lbl {\n    font-size: 9px; font-weight: 800; letter-spacing: 0.14em;\n    text-transform: uppercase; color: var(--text3); margin-top: 6px;\n  }\n  .sd-arrow {\n    position: relative; height: 2px;\n    background: linear-gradient(90deg, var(--green), var(--cyan));\n    border-radius: 99px;\n  }\n  .sd-arrow::after {\n    content: \"\"; position: absolute; right: -3px; top: -5px;\n    width: 0; height: 0;\n    border-left: 10px solid var(--cyan);\n    border-top: 6px solid transparent;\n    border-bottom: 6px solid transparent;\n  }\n  .sd-arrow .pulse {\n    position: absolute; left: 0; top: -3px;\n    width: 8px; height: 8px; border-radius: 50%;\n    background: var(--green);\n    box-shadow: 0 0 14px var(--green);\n    animation: sd-flow 2.2s linear infinite;\n  }\n  @keyframes sd-flow {\n    0% { left: 0; opacity: 0; }\n    10% { opacity: 1; }\n    90% { opacity: 1; }\n    100% { left: calc(100% - 8px); opacity: 0; }\n  }\n  .sd-export-badge {\n    position: absolute; bottom: 4px; left: 50%; transform: translateX(-50%);\n    background: var(--grad); color: #fff;\n    padding: 5px 14px; border-radius: 99px;\n    font-size: 10px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase;\n    box-shadow: 0 8px 20px rgba(0,196,122,0.35);\n    display: inline-flex; align-items: center; gap: 6px;\n  }\n  .sd-export-badge::before {\n    content: \"✓\"; font-size: 10px;\n    background: rgba(255,255,255,0.25); width: 15px; height: 15px;\n    border-radius: 50%; display: inline-flex; align-items: center; justify-content: center;\n  }\n\n  @media (max-width: 1000px) { .sol-diffs-row { grid-template-columns: 1fr 1fr; } }\n  @media (max-width: 600px)  { .sol-diffs-row { grid-template-columns: 1fr; margin-top: 48px; } }\n</style>\n</head>\n<body>\n\n<!-- NAV -->\n<header class=\"nav\">\n  <div class=\"wrap nav-inner\">\n    <a href=\"index.html\" class=\"nav-logo\"><span class=\"vita\">vita</span><span class=\"id-box\">id</span></a>\n    <nav class=\"nav-links\">\n      <a href=\"medico.html\" class=\"current\">Para médicos</a>\n      <a href=\"paciente.html\">Para pacientes</a>\n      <a href=\"#como\">Como funciona</a>\n      <div style=\"margin-top:14px;padding:10px 12px;background:rgba(0,0,0,.03);border-radius:10px;font-size:11px;color:#6B7280;line-height:1.5\">Considera <strong style=\"color:#4B5563\">~4 min poupados por consulta</strong> (medida em pacientes reais do vita) e <strong style=\"color:#4B5563\">10% de faltas</strong> (média Brasil — FENAM). No app, voce calibra com seus numeros.</div>\n          <a href=\"#cta\" class=\"btn btn-primary\" style=\"padding: 9px 20px; font-size: 13px;\">Testar grátis</a>\n    </nav>\n    <button class=\"nav-mobile-btn\" aria-label=\"Menu\" id=\"open-menu\"><span></span></button>\n  </div>\n</header>\n\n<!-- MOBILE MENU -->\n<div class=\"mobile-menu\" id=\"mobile-menu\">\n  <div class=\"panel\">\n    <div class=\"head\">\n      <a href=\"index.html\" class=\"nav-logo\"><span class=\"vita\">vita</span><span class=\"id-box\">id</span></a>\n      <button class=\"close\" id=\"close-menu\" aria-label=\"Fechar\">×</button>\n    </div>\n    <a href=\"medico.html\">Para médicos</a>\n    <a href=\"paciente.html\">Para pacientes</a>\n    <a href=\"#como\">Como funciona</a>\n    <a href=\"medico.html#faq\">FAQ</a>\n    <a href=\"#cta\" class=\"cta\">Testar 7 dias grátis</a>\n  </div>\n</div>\n\n<!-- HERO -->\n<section class=\"m-hero\" data-screen-label=\"01 hero médico\">\n  <div class=\"wrap\">\n    <div class=\"m-hero-grid\">\n      <div class=\"reveal\">\n        <div class=\"kicker\">\n          <span class=\"tag live\">Para médicos · Pré-consulta inteligente</span>\n        </div>\n        <h1>A pré-consulta inteligente do <span class=\"grad-text\">médico moderno.</span></h1>\n        <p class=\"lead\">O paciente preenche antes. Você ouve um resumo de 60 segundos e entra na sala já sabendo tudo.</p>\n        <div class=\"ctas\">\n          <a href=\"#cta\" class=\"btn btn-primary\">Testar 7 dias grátis <span class=\"arrow\">→</span></a>\n          <a href=\"#como\" class=\"btn btn-ghost\">Ver como funciona</a>\n        </div>\n        <div class=\"hero-stats\">\n          <div><div class=\"v\"><span class=\"a\">7-15</span> min</div><div class=\"l\">perdidos por consulta com burocracia</div></div>\n          <div><div class=\"v\"><span class=\"a\">+12</span>%</div><div class=\"l\">de receita potencial por dia</div></div>\n          <div><div class=\"v\"><span class=\"a\">60</span>s</div><div class=\"l\">de áudio com tudo que você precisa</div></div>\n        </div>\n      </div>\n\n      <div class=\"calc-card reveal\" data-d=\"1\" id=\"calc\">\n        <div class=\"calc-head\">\n          <div class=\"title\">O quanto você está perdendo</div>\n          <div class=\"meta\">tempo real</div>\n        </div>\n        <div class=\"calc-row\">\n          <div class=\"top\"><span class=\"lbl\">Consultas por dia</span><span class=\"val\" id=\"v-cons\">5</span></div>\n          <div class=\"slider-wrap\"><input type=\"range\" class=\"slider\" min=\"2\" max=\"20\" step=\"1\" value=\"5\" data-k=\"cons\" data-min=\"2\" data-max=\"20\"></div>\n        </div>\n        <div class=\"calc-row\">\n          <div class=\"top\"><span class=\"lbl\">Duração atual por consulta</span><span class=\"val\" id=\"v-dur\">60 min</span></div>\n          <div class=\"slider-wrap\"><input type=\"range\" class=\"slider\" min=\"15\" max=\"90\" step=\"5\" value=\"60\" data-k=\"dur\" data-min=\"15\" data-max=\"90\"></div>\n        </div>\n        <div class=\"calc-row\">\n          <div class=\"top\"><span class=\"lbl\">Valor por consulta</span><span class=\"val\" id=\"v-val\">R$ 600</span></div>\n          <div class=\"slider-wrap\"><input type=\"range\" class=\"slider\" min=\"100\" max=\"2000\" step=\"50\" value=\"600\" data-k=\"val\" data-min=\"100\" data-max=\"2000\"></div>\n        </div>\n        <div class=\"calc-row\">\n          <div class=\"top\"><span class=\"lbl\">Dias trabalhados por mês</span><span class=\"val\" id=\"v-dias\">20 dias</span></div>\n          <div class=\"slider-wrap\"><input type=\"range\" class=\"slider\" min=\"5\" max=\"30\" step=\"1\" value=\"20\" data-k=\"dias\" data-min=\"5\" data-max=\"30\"></div>\n        </div>\n\n        <div class=\"calc-result\">\n          <div class=\"l\">Você pode faturar a mais por mês</div>\n          <div class=\"big\" id=\"r-big\">+ R$ 12.000</div>\n          <div class=\"sub\" id=\"r-sub\">+1 consulta/dia · 20 dias · R$ 600 cada</div>\n          <div class=\"bar\"><i id=\"r-bar\" style=\"width: 35%;\"></i></div>\n          <a href=\"#cta\" class=\"btn btn-primary\" style=\"margin-top: 20px; width: 100%; justify-content: center;\">Quero esse resultado <span class=\"arrow\">→</span></a>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- O PROBLEMA -->\n<section class=\"section bg-2\" data-screen-label=\"02 problema\">\n  <div class=\"wrap\">\n    <div class=\"reveal\" style=\"text-align: center;\">\n      <span class=\"tag\">O problema</span>\n      <h2 class=\"prob-headline\">De 10 a 15 minutos de cada consulta <span class=\"grad-text\">são gastos com anamnese.</span></h2>\n    </div>\n\n    <div class=\"pillars reveal\" data-d=\"1\" style=\"margin-top: 72px;\">\n      <!-- Pillar 1: Histórico de exames — dor -->\n      <article class=\"pillar\">\n        <span class=\"badge\">Histórico de exames</span>\n        <h3>\"Fiz, mas não trouxe.\"</h3>\n        <p>Você pede o exame de novo. O paciente perde tempo. O plano paga duas vezes. E você começa do zero — sem saber se houve tendência.</p>\n        <div class=\"vis\">\n          <div class=\"p1-lbl\">LDL · 6 meses</div>\n          <div class=\"p1-chart pain\">\n            <i style=\"height: 0; opacity: 0.15;\"></i>\n            <i style=\"height: 0; opacity: 0.15;\"></i>\n            <i style=\"height: 0; opacity: 0.15;\"></i>\n            <i style=\"height: 0; opacity: 0.15;\"></i>\n            <i style=\"height: 0; opacity: 0.15;\"></i>\n            <i class=\"pain-last\" style=\"height: 40%;\"></i>\n          </div>\n          <div class=\"p1-meta\">\n            <span>nov · dez · jan · fev · mar · abr</span>\n            <span class=\"miss\">? sem dados</span>\n          </div>\n        </div>\n      </article>\n\n      <!-- Pillar 2: Histórico clínico — dor -->\n      <article class=\"pillar\">\n        <span class=\"badge\">Histórico clínico</span>\n        <h3>Página em branco.</h3>\n        <p>Você descobre tudo na hora. Cada consulta começa do zero, com 10 minutos só para reconstruir o que já existia.</p>\n        <div class=\"vis\">\n          <div class=\"p2-list\">\n            <div class=\"p2-item miss\">Queixa principal <span class=\"qm\">?</span></div>\n            <div class=\"p2-item miss\">Medicamentos em uso <span class=\"qm\">?</span></div>\n            <div class=\"p2-item miss\">Alergias <span class=\"qm\">?</span></div>\n            <div class=\"p2-item miss\">Histórico familiar <span class=\"qm\">?</span></div>\n          </div>\n        </div>\n      </article>\n\n      <!-- Pillar 3: Medicamentos — dor -->\n      <article class=\"pillar\">\n        <span class=\"badge\">Medicamentos</span>\n        <h3>\"Acho que tomo um para pressão…\"</h3>\n        <p>Nome? Não sabe. Dose? Não lembra. Você prescreve com menos segurança — e o risco de interação aparece só depois.</p>\n        <div class=\"vis\">\n          <div class=\"p3-list\">\n            <div class=\"p3-med miss\">\n              <div class=\"nm\">\"Um amarelinho…\"</div>\n              <div class=\"meta\">dose? · <b class=\"q\">desconhecido</b></div>\n            </div>\n            <div class=\"p3-med miss\">\n              <div class=\"nm\">\"E mais um pequeno…\"</div>\n              <div class=\"meta\">frequência? · <b class=\"q\">desconhecido</b></div>\n            </div>\n            <div class=\"p3-alert\">Risco de interação desconhecido</div>\n          </div>\n        </div>\n      </article>\n    </div>\n\n    <p class=\"prob-subtext reveal\" data-d=\"2\">Não porque você quer. Porque o sistema te obriga. Cada paciente chega como uma página em branco — e você tem 60 minutos para descobrir tudo do zero.</p>\n  </div>\n</section>\n\n<!-- A SOLUÇÃO -->\n<section class=\"section showcase\" id=\"como\" data-screen-label=\"03 solução\">\n  <div class=\"wrap\">\n    <div class=\"sol-2col reveal\">\n      <!-- LEFT: heading + features list -->\n      <div class=\"sol-left\">\n        <span class=\"tag\">A solução</span>\n        <h2 class=\"sol-headline\">Você entra na sala <span class=\"grad-text\">já sabendo tudo.</span></h2>\n        <div class=\"sol-features\">\n          <div class=\"sol-feat\">\n            <div class=\"n\">01</div>\n            <div>\n              <h4>Anamnese estruturada</h4>\n              <p>O paciente preenche antes. Você recebe organizado — sem ter perguntado nada.</p>\n            </div>\n          </div>\n          <div class=\"sol-feat\">\n            <div class=\"n\">02</div>\n            <div>\n              <h4>One Minute Summary</h4>\n              <p>60 segundos de áudio no corredor — antes de você entrar.</p>\n            </div>\n          </div>\n          <div class=\"sol-feat\">\n            <div class=\"n\">03</div>\n            <div>\n              <h4>Histórico sempre acessível</h4>\n              <p>Exames e documentos num só lugar. Sem papel. Sem foto no celular.</p>\n            </div>\n          </div>\n          <div class=\"sol-feat\">\n            <div class=\"n\">04</div>\n            <div>\n              <h4>Exporta pro prontuário <span class=\"new-pill\">NOVO</span></h4>\n              <p>Depois da consulta, você não escreve mais nada. Zero retrabalho.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- RIGHT: hero image -->\n      <div class=\"sol-right\">\n        <img src=\"6a805543-5166-4d29-9bbe-769b1689ad39\" alt=\"vitaid · dashboard médico, RG da Saúde no celular, pergunta da anamnese, waveform de áudio e gráfico de pré-consultas respondidas\" class=\"sol-img\">\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- BOX 1 — Envia pré-consulta (vídeo motion) -->\n<section class=\"section\" id=\"box-pre-consulta\" data-screen-label=\"04 box 1 pre-consulta\">\n  <div class=\"wrap\">\n    <div class=\"reveal\" style=\"display:grid; grid-template-columns:1fr 1.15fr; gap:60px; align-items:center\">\n      <div>\n        <span class=\"tag\" style=\"margin-bottom:16px; display:inline-block\">01 · Antes da consulta</span>\n        <h2 style=\"font-size:40px; line-height:1.05; letter-spacing:-1.2px; font-weight:800; margin:14px 0 20px\">Envia a <span class=\"grad-text\">pré-consulta</span> antes da consulta do seu paciente.</h2>\n        <p class=\"lead\" style=\"font-size:17px; line-height:1.55; margin-bottom:24px\">Em 3 cliques você manda pelo WhatsApp. O paciente responde quando puder — no caminho, no metrô, depois do almoço. E você chega na consulta já preparado, sem perder 15 minutos refazendo anamnese.</p>\n        <ul style=\"list-style:none; padding:0; margin:0\">\n          <li style=\"font-size:15px; line-height:1.55; padding:8px 0 8px 26px; position:relative\"><span style=\"position:absolute; left:0; top:14px; width:12px; height:12px; background:linear-gradient(120deg,#00E5A0,#00B4D8); border-radius:50%; box-shadow:0 0 0 4px rgba(0,229,160,.12)\"></span><strong style=\"font-weight:700\">3 cliques</strong> pra montar e enviar — paciente, template, mensagem.</li>\n          <li style=\"font-size:15px; line-height:1.55; padding:8px 0 8px 26px; position:relative\"><span style=\"position:absolute; left:0; top:14px; width:12px; height:12px; background:linear-gradient(120deg,#00E5A0,#00B4D8); border-radius:50%; box-shadow:0 0 0 4px rgba(0,229,160,.12)\"></span><strong style=\"font-weight:700\">WhatsApp direto</strong> — o canal que o paciente já usa todo dia.</li>\n          <li style=\"font-size:15px; line-height:1.55; padding:8px 0 8px 26px; position:relative\"><span style=\"position:absolute; left:0; top:14px; width:12px; height:12px; background:linear-gradient(120deg,#00E5A0,#00B4D8); border-radius:50%; box-shadow:0 0 0 4px rgba(0,229,160,.12)\"></span><strong style=\"font-weight:700\">Link rastreável</strong> — você sabe quando ele abriu e respondeu.</li>\n        </ul>\n      </div>\n      <div style=\"position:relative; width:100%; aspect-ratio:16/9; border-radius:18px; overflow:hidden; background:#F7F8FB; box-shadow:0 1px 2px rgba(13,15,20,.04), 0 32px 64px -20px rgba(13,15,20,.22)\">\n        <video autoplay loop muted playsinline preload=\"metadata\" style=\"width:100%; height:100%; object-fit:cover; display:block\">\n          <source src=\"docs/marketing/videos/flow-pre-consulta.webm\" type=\"video/webm\">\n        </video>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<!-- CUSTO REAL — Antes vs Depois -->\n<section class=\"section bg-2\" data-screen-label=\"04 custo real\">\n  <div class=\"wrap\">\n    <div class=\"sh reveal\">\n      <span class=\"tag\">O custo real</span>\n      <h2>Antes do vitaid. <span class=\"grad-text\">Depois do vitaid.</span></h2>\n      <p class=\"lead\">Cada minuto perdido com anamnese repetitiva é um minuto que você poderia usar para diagnosticar melhor — ou atender mais um paciente.</p>\n    </div>\n\n    <div class=\"vs-grid reveal\" data-d=\"1\">\n      <!-- Sem vitaid -->\n      <div class=\"vs-card\">\n        <div class=\"vs-head\">\n          <span class=\"badge red\">Sem vitaid</span>\n        </div>\n        <div class=\"vs-row\">\n          <span class=\"t\">Anamnese repetida do zero em cada consulta</span>\n          <span class=\"b red\">+ 15 min</span>\n        </div>\n        <div class=\"vs-row\">\n          <span class=\"t\">Paciente não sabe o nome do remédio que toma</span>\n          <span class=\"b red\">Dado incerto</span>\n        </div>\n        <div class=\"vs-row\">\n          <span class=\"t\">Exame não trouxe, você pede de novo</span>\n          <span class=\"b red\">Duplicado</span>\n        </div>\n        <div class=\"vs-row\">\n          <span class=\"t\">Prescrição às pressas — próximo paciente esperando</span>\n          <span class=\"b red\">Erro de margem</span>\n        </div>\n        <div class=\"vs-row\">\n          <span class=\"t\">Redigita no prontuário o que o paciente já disse</span>\n          <span class=\"b red\">Retrabalho</span>\n        </div>\n        <div class=\"vs-foot\">\n          <span class=\"l\">Resultado</span>\n          <span class=\"v\">5 consultas / dia</span>\n        </div>\n      </div>\n\n      <!-- Com vitaid -->\n      <div class=\"vs-card com\">\n        <div class=\"vs-head\">\n          <span class=\"badge green\">Com vitaid</span>\n        </div>\n        <div class=\"vs-row\">\n          <span class=\"t\">Anamnese estruturada preenchida antes da consulta</span>\n          <span class=\"b green\">Automático</span>\n        </div>\n        <div class=\"vs-row\">\n          <span class=\"t\">Medicamentos, doses e alergias — exatos, confirmados</span>\n          <span class=\"b green\">Verificado</span>\n        </div>\n        <div class=\"vs-row\">\n          <span class=\"t\">Histórico de exames interligados ao longo do tempo</span>\n          <span class=\"b green\">Tendência</span>\n        </div>\n        <div class=\"vs-row\">\n          <span class=\"t\">Você ouve o resumo de 60s antes de entrar na sala</span>\n          <span class=\"b green\">1 min · áudio</span>\n        </div>\n        <div class=\"vs-row\">\n          <span class=\"t\">Exporta pro prontuário — zero retrabalho</span>\n          <span class=\"b green\">1 clique</span>\n        </div>\n        <div class=\"vs-foot\">\n          <span class=\"l\">Resultado</span>\n          <span class=\"v\">6–7 consultas / dia</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- DEPOIMENTO -->\n<section class=\"section compact\" data-screen-label=\"05 depoimento\">\n  <div class=\"wrap reveal\">\n    <div class=\"testim\">\n      <span class=\"tag\" style=\"margin-bottom: 4px; display: inline-flex;\">O que médicos dizem</span>\n      <p class=\"quote\">\"Entrei na sala sabendo que o André tinha HbA1c em 7.8%, picos noturnos e alergia a sulfonamidas. Fui direto para o que importava. Ele me olhou diferente. Percebi que nunca tinha me sentido tão preparado numa consulta.\"</p>\n      <div class=\"author\">\n        <div class=\"av\">DR</div>\n        <div>\n          <div style=\"font-weight: 800; color: var(--text1);\">Dr. Ricardo Souza</div>\n          <div style=\"color: var(--text3); font-size: 13px;\">Endocrinologista · São Paulo</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- FAQ -->\n<section class=\"section bg-2\" id=\"faq\" data-screen-label=\"06 faq\">\n  <div class=\"wrap faq\">\n    <div class=\"reveal\" style=\"text-align: center;\">\n      <span class=\"tag\">Dúvidas frequentes</span>\n      <h2 style=\"margin-top: 14px;\">Perguntas que todo médico faz.</h2>\n    </div>\n    <div class=\"faq-list reveal\" data-d=\"1\">\n      <div class=\"faq-item\">\n        <div class=\"q\"><span>O paciente precisa baixar algum app?</span> <span class=\"ic\">+</span></div>\n        <div class=\"a\"><p>Não. O paciente recebe um link e preenche direto no navegador do celular. Sem cadastro, sem app, sem atrito.</p></div>\n      </div>\n      <div class=\"faq-item\">\n        <div class=\"q\"><span>Funciona para qualquer especialidade?</span> <span class=\"ic\">+</span></div>\n        <div class=\"a\"><p>Sim. Você configura sua especialidade e o formulário de pré-consulta é personalizado automaticamente — as perguntas certas para cada tipo de consulta.</p></div>\n      </div>\n      <div class=\"faq-item\">\n        <div class=\"q\"><span>Os dados dos pacientes ficam seguros?</span> <span class=\"ic\">+</span></div>\n        <div class=\"a\"><p>100%. Todos os dados são criptografados em trânsito e em repouso. O vitaid é totalmente aderente à LGPD. Você e o paciente definem quem acessa o quê.</p></div>\n      </div>\n      <div class=\"faq-item\">\n        <div class=\"q\"><span>Quanto tempo leva para começar a usar?</span> <span class=\"ic\">+</span></div>\n        <div class=\"a\"><p>Menos de 5 minutos. Você cria sua conta, configura sua especialidade e já tem um link personalizado para enviar ao seu primeiro paciente.</p></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- CTA FINAL -->\n<section class=\"cta-final\" id=\"cta\" data-screen-label=\"07 cta\">\n  <div class=\"wrap reveal\">\n    <span class=\"eyebrow\">Acesso antecipado</span>\n    <h2>Seja o médico que <span class=\"grad-text\">chega preparado.</span></h2>\n    <p class=\"lead\" style=\"margin-left: auto; margin-right: auto;\">Acesso antecipado para médicos. Primeiros 100 usuários com condições especiais.</p>\n    <form class=\"email-row\" onsubmit=\"event.preventDefault(); const b=this.querySelector('button'); b.textContent='✓ Pronto'; b.style.opacity='0.92';\">\n      <input type=\"email\" placeholder=\"seu@email.com\" required=\"\">\n      <button type=\"submit\" class=\"btn btn-primary\">Garantir vaga</button>\n    </form>\n    <div class=\"note\">R$ 19,99/mês · Sem fidelidade · Cancele quando quiser</div>\n  </div>\n</section>\n\n<!-- FOOTER -->\n<footer class=\"footer\">\n  <div class=\"wrap\">\n    <div>\n      <a href=\"index.html\" class=\"nav-logo\" style=\"font-size: 26px;\"><span class=\"vita\">vita</span><span class=\"id-box\" style=\"font-size: 26px;\">id</span></a>\n      <p style=\"font-size: 14px; margin-top: 16px; max-width: 32ch; color: var(--text3);\">A entrada da consulta, reinventada. Para quem chega preparado.</p>\n    </div>\n    <div><h5>Produto</h5><a href=\"medico.html\">Para médicos</a><a href=\"paciente.html\">Para pacientes</a><a href=\"#como\">Como funciona</a><a href=\"#faq\">FAQ</a></div>\n    <div><h5>Empresa</h5><a href=\"#\">Manifesto</a><a href=\"#\">Imprensa</a><a href=\"#\">Trabalhe conosco</a></div>\n    <div><h5>Legal</h5><a href=\"#\">Privacidade · LGPD</a><a href=\"#\">Termos de uso</a><a href=\"#\">Segurança</a></div>\n  </div>\n  <div class=\"wrap footer-bottom\">\n    <div>© 2026 vitaid · Todos os direitos reservados</div>\n    <div class=\"mono\">v 1.0 · beta privado</div>\n  </div>\n</footer>\n\n<script>\n  // Reveal\n  (function () {\n    const els = Array.from(document.querySelectorAll('.reveal'));\n    const showInView = () => {\n      const vh = window.innerHeight;\n      els.forEach(el => {\n        if (el.classList.contains('in')) return;\n        const r = el.getBoundingClientRect();\n        if (r.top < vh + 100) el.classList.add('in');\n      });\n    };\n    requestAnimationFrame(showInView);\n    try {\n      const io = new IntersectionObserver((es) => {\n        for (const e of es) if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }\n      }, { threshold: 0.05 });\n      els.forEach(el => io.observe(el));\n    } catch (_) {}\n    setTimeout(() => els.forEach(el => el.classList.add('in')), 1500);\n  })();\n\n  // Mobile menu\n  (function () {\n    const menu = document.getElementById('mobile-menu');\n    const open = document.getElementById('open-menu');\n    const close = document.getElementById('close-menu');\n    if (!menu || !open) return;\n    open.addEventListener('click', () => { menu.classList.add('open'); document.body.style.overflow = 'hidden'; });\n    const dismiss = () => { menu.classList.remove('open'); document.body.style.overflow = ''; };\n    close && close.addEventListener('click', dismiss);\n    menu.addEventListener('click', (e) => { if (e.target === menu) dismiss(); });\n    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', dismiss));\n  })();\n\n  // Calculator\n  (function () {\n    const state = { cons: 5, dur: 60, val: 600, dias: 20 };\n    const fmt = v => 'R$ ' + v.toLocaleString('pt-BR');\n\n    function fillSlider(el) {\n      const min = parseFloat(el.dataset.min), max = parseFloat(el.dataset.max);\n      const v = parseFloat(el.value);\n      el.style.backgroundSize = (((v - min) / (max - min)) * 100) + '% 100%';\n    }\n\n    function render() {\n      document.getElementById('v-cons').textContent = state.cons;\n      document.getElementById('v-dur').textContent  = state.dur + ' min';\n      document.getElementById('v-val').textContent  = fmt(state.val);\n      document.getElementById('v-dias').textContent = state.dias + ' dias';\n\n      // Metodologia vitae: 4 min poupados por consulta (Obsidian P7) + 10% no-show (FENAM)\n      const MIN_POUPADOS_POR_PC = 4;\n      const NO_SHOW = 0.10;\n      const tempoEconomizadoMes = MIN_POUPADOS_POR_PC * state.cons * state.dias;\n      const extraPerDay = Math.max(0, Math.floor((MIN_POUPADOS_POR_PC * state.cons) / state.dur));\n      const extraConsultasMes = Math.floor(tempoEconomizadoMes / state.dur);\n      const extraMonth = Math.floor(extraConsultasMes * state.val * (1 - NO_SHOW));\n\n      const big = document.getElementById('r-big');\n      big.textContent = '+ ' + fmt(extraMonth);\n      big.style.filter = 'brightness(1.2)';\n      setTimeout(() => big.style.filter = '', 250);\n\n      document.getElementById('r-sub').textContent =\n        `+${extraConsultasMes} consulta${extraConsultasMes===1?'':'s'}/mês · ${fmt(state.val)} cada · ${tempoEconomizadoMes} min poupados`;\n      document.getElementById('r-bar').style.width =\n        Math.min(100, 18 + extraMonth / 350) + '%';\n    }\n\n    document.querySelectorAll('#calc .slider').forEach(s => {\n      fillSlider(s);\n      s.addEventListener('input', () => {\n        state[s.dataset.k] = parseFloat(s.value);\n        fillSlider(s);\n        render();\n      });\n    });\n    render();\n  })();\n\n  // Showcase waveform bars (colored: red/yellow/green active, gray rest)\n  (function () {\n    const w = document.getElementById('sc-wave-bars');\n    if (!w) return;\n    const colors = ['#EF4444','#EF4444','#F59E0B','#F59E0B','#F59E0B','#00C47A','#00C47A','#00C47A','#00C47A','#00C47A','#00C47A','#00C47A'];\n    let html = '';\n    for (let i = 0; i < 16; i++) {\n      const h = 8 + Math.round(Math.abs(Math.sin(i*0.6))*12 + Math.random()*4);\n      const c = i < colors.length ? colors[i] : '#E5E7EB';\n      html += `<i style=\"height:${h}px; background:${c}\"></i>`;\n    }\n    w.innerHTML = html;\n  })();\n\n  // Mini diff card waveform\n  (function () {\n    const w = document.getElementById('sd-wave');\n    if (!w) return;\n    const N = 26, played = 11; let html = '';\n    for (let i = 0; i < N; i++) {\n      const h = 4 + Math.round(Math.abs(Math.sin(i*0.6))*16 + Math.random()*4);\n      const cls = i < played ? '' : ' class=\"off\"';\n      html += `<i${cls} style=\"height:${h}px\"></i>`;\n    }\n    w.innerHTML = html;\n  })();\n\n  // Solução waveform\n  (function () {\n    const w = document.getElementById('sol-wave');\n    if (!w) return;\n    const N = 50, played = 22; let html = '';\n    for (let i = 0; i < N; i++) {\n      const h = 4 + Math.round(Math.abs(Math.sin(i*0.4))*18 + Math.random()*6);\n      const cls = i < played ? '' : ' class=\"off\"';\n      html += `<i${cls} style=\"height:${h}px\"></i>`;\n    }\n    w.innerHTML = html;\n  })();\n\n  // FAQ\n  document.querySelectorAll('.faq-item').forEach(item => {\n    item.addEventListener('click', () => item.classList.toggle('open'));\n  });\n  const firstFaq = document.querySelector('.faq-item'); if (firstFaq) firstFaq.classList.add('open');\n<\/script>\n\n\n</body></html>"</script>
