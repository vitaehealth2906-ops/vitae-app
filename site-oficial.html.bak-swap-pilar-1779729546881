ight: 92%; background: linear-gradient(180deg, var(--green) 0%, var(--cyan) 100%); }\n  .sc-x {\n    display: flex; justify-content: space-between; padding: 0 4px;\n    font-size: 9px; color: var(--text4); font-family: var(--font-mono); font-weight: 600;\n    margin-top: 10px;\n  }\n\n  /* Mobile: stack into a phone + MacBook scaled */\n  @media (max-width: 900px) {\n    .sc-stage { height: auto; max-width: 100%; }\n    .sc-mb { position: static; transform: none; width: 100%; max-width: 460px; margin: 0 auto; }\n    .sc-phone-left, .sc-phone-right { display: none; }\n    .sc-wave { position: static; transform: none; margin: 24px auto 0; }\n    .sc-chart { position: static; margin: 16px auto 0; width: 100%; max-width: 280px; }\n  }\n  @media (max-width: 500px) {\n    .sc-mb .screen { grid-template-columns: 1fr; }\n    .sc-mb-side { display: none; }\n  }\n\n  /* ============ Solução 2-col (text left, devices right) ============ */\n  .sol-2col {\n    display: grid;\n    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.15fr);\n    gap: 56px;\n    align-items: center;\n  }\n  .sol-left { max-width: 520px; }\n  .sol-left .sol-headline {\n    text-align: left;\n    max-width: 13ch;\n    margin: 16px 0 0;\n  }\n  .sol-features {\n    margin-top: 36px;\n    display: flex; flex-direction: column;\n  }\n  .sol-feat {\n    padding: 22px 0 22px 0;\n    border-top: 1px solid var(--bg3);\n    display: grid;\n    grid-template-columns: 56px 1fr;\n    gap: 18px;\n    align-items: flex-start;\n    position: relative;\n    transition: padding .35s var(--ease);\n  }\n  .sol-feat:last-of-type { border-bottom: 1px solid var(--bg3); }\n  .sol-feat::before {\n    content: \"\"; position: absolute; left: -16px; top: 22px; bottom: 22px;\n    width: 3px; border-radius: 99px;\n    background: var(--grad);\n    opacity: 0; transform: scaleY(0.4); transform-origin: center;\n    transition: opacity .3s var(--ease), transform .35s var(--ease);\n  }\n  .sol-feat:hover { padding-left: 16px; }\n 