U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n/* cyrillic-ext */\n@font-face {\n  font-family: 'Plus Jakarta Sans';\n  font-style: normal;\n  font-weight: 800;\n  font-display: swap;\n  src: url(\"02c959fb-dec5-4df4-8f3a-9e00d38080fe\") format('woff2');\n  unicode-range: U+0460-052F, U+1C80-1C8A, U+20B4, U+2DE0-2DFF, U+A640-A69F, U+FE2E-FE2F;\n}\n/* vietnamese */\n@font-face {\n  font-family: 'Plus Jakarta Sans';\n  font-style: normal;\n  font-weight: 800;\n  font-display: swap;\n  src: url(\"2d5f47cc-820c-4865-9160-d42b8918197e\") format('woff2');\n  unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'Plus Jakarta Sans';\n  font-style: normal;\n  font-weight: 800;\n  font-display: swap;\n  src: url(\"02fbfe62-b00d-4446-9cd8-c8315b90e33c\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Plus Jakarta Sans';\n  font-style: normal;\n  font-weight: 800;\n  font-display: swap;\n  src: url(\"b5f88c9a-24d5-4989-a51e-a58facd23047\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n</style>\n<style>/* =========================================================================\n   vitaid — identidade visual (light-mode primary, Plus Jakarta Sans)\n   ========================================================================= */\n\n:root {\n  /* Brand */\n  --green: #00C47A;\n  --cyan:  #0099B8;\n  --grad:  linear-gradient(120deg, #00C47A, #0099B8);\n\n  /* Light neutrals */\n  --bg:    #FFFFFF;\n  --bg2:   #F5F7FA;\n  --bg3:   #ECEEF2;\n  --bg4:   #E5E7EB;\n  --text1: #0D0F14;\n  --text2: #374151;\n  --text3: #6B7280;\n  --text4: #9CA3AF;\n  --border:        rgba(0,0,0,0.08);\n  --border-strong: rgba(0,0,0,0.12);\n\n  /* Dark (only for product UI) */\n  --dark:  #0D0F14;\n  --dark2: #131619;\n  --dark3: #1A1E26;\n  --dark4: #222830;\n\n  /* State */\n  --red:    #EF4444;\n  --red-bg: #FEE2E2;\n  --amber:  #F59E0B;\n  --amber-bg: rgba(245,158,11,0.10);\n  --green-bg: rgba(0,196,122,0.10);\n\n  /* Radius */\n  --r:    16px;\n  --r-sm: 10px;\n  --r-lg: 24px;\n  --r-pill: 100px;\n\n  /* Shadow */\n  --sh-sm: 0 2px 8px rgba(0,0,0,0.04);\n  --sh-md: 0 8px 32px rgba(0,0,0,0.08);\n  --sh-lg: 0 24px 64px rgba(0,0,0,0.12);\n  --sh-brand-sm: 0 0 24px rgba(0,196,122,0.20);\n  --sh-brand-md: 0 8px 32px rgba(0,196,122,0.10);\n\n  /* Type */\n  --font: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;\n  --font-mono: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;\n\n  /* Transition */\n  --ease: cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n* { box-sizing: border-box; }\nhtml, body {\n  margin: 0;\n  background: var(--bg);\n  color: var(--text1);\n  font-family: var(--font);\n  -webkit-font-smoothing: antialiased;\n  text-rendering: optimizeLegibility;\n  font-feature-settings: \"ss01\", \"cv11\";\n}\nimg { display: block; max-width: 100%; }\na { color: inherit; text-decoration: none; }\nbutton { font: inherit; color: inherit; background: none; border: 0; cursor: pointer; }\n\n/* =========================================================================\n   Type\n   ========================================================================= */\n\nh1, h2, h3, h4, h5 { margin: 0; font-family: var(--font); }\n\nh1 {\n  font-size: clamp(36px, 5vw, 60px);\n  font-weight: 800;\n  letter-spacing: -2px;\n  line-height: 1.05;\n  color: var(--text1);\n}\nh2 {\n  font-size: clamp(28px, 3.6vw, 44px);\n  font-weight: 800;\n  letter-spacing: -1.2px;\n  line-height: 1.1;\n  color: var(--text1);\n}\nh3 {\n  font-size: clamp(18px, 1.6vw, 22px);\n  font-weight: 800;\n  letter-spacing: -0.5px;\n  line-height: 1.2;\n  color: var(--text1);\n}\nh4 {\n  font-size: 17px;\n  font-weight: 800;\n  letter-spacing: -0.5px;\n  color: var(--text1);\n}\n\np {\n  margin: 0;\n  font-size: 15px;\n  line-height: 1.7;\n  color: var(--text2);\n  font-weight: 400;\n  text-wrap: pretty;\n}\n\n.lead {\n  font-size: clamp(17px, 1.3vw, 19px);\n  line-height: 1.65;\n  color: var(--text2);\n  max-width: 60ch;\n  text-wrap: pretty;\n}\n\n.eyebrow {\n  font-size: 11px;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.12em;\n  color: var(--text3);\n}\n\n.muted { color: var(--text3); }\n.dim   { color: var(--text4); }\n\n.mono {\n  font-family: var(--font-mono);\n  font-feature-settings: \"tnum\";\n  letter-spacing: 0;\n}\n\n/* Gradient text utility */\n.grad-text {\n  background: var(--grad);\n  -webkit-background-clip: text;\n  background-clip: text;\n  color: transparent;\n  -webkit-text-fill-color: transparent;\n  /* Slight padding to avoid clipped descenders */\n  padding-right: 0.04em;\n}\n\n/* =========================================================================\n   Layout\n   ========================================================================= */\n\n.wrap {\n  max-width: 1180px;\n  margin: 0 auto;\n  padding: 0 clamp(20px, 5vw, 80px);\n}\n\n.section {\n  padding: clamp(64px, 8vw, 100px) 0;\n  position: relative;\n}\n.section.compact { padding: clamp(48px, 6vw, 80px) 0; }\n.section.tight   { padding: clamp(40px, 5vw, 64px) 0; }\n\n/* Alternating backgrounds: every other section gets bg2.\n   For explicit control, use class .bg-1 / .bg-2 / .bg-3 */\n.bg-1 { background: var(--bg); }\n.bg-2 { background: var(--bg2); }\n.bg-3 { background: var(--bg3); }\n.bg-dark { background: var(--dark); color: #fff; }\n\n.divider { height: 1px; background: var(--bg3); border: 0; margin: 0; }\n\n/* =========================================================================\n   Logo\n   ========================================================================= */\n\n.nav-logo {\n  display: inline-flex;\n  align-items: center;\n  font-family: var(--font);\n  font-weight: 800;\n  font-size: 22px;\n  letter-spacing: -0.5px;\n  color: var(--text1);\n  gap: 0;\n}\n.nav-logo .vita { color: var(--text1); }\n.nav-logo .id-box {\n  background: var(--grad);\n  color: #fff;\n  font-weight: 800;\n  font-size: 22px;\n  padding: 0px 7px 2px;\n  border-radius: 6px;\n  margin-left: 2px;\n  letter-spacing: -0.5px;\n  line-height: 1.15;\n}\n.nav-logo.invert .vita { color: #fff; }\n\n/* =========================================================================\n   Nav\n   ========================================================================= */\n\n.nav {\n  position: sticky; top: 0; z-index: 50;\n  background: rgba(255,255,255,0.85);\n  backdrop-filter: blur(16px) saturate(1.3);\n  -webkit-backdrop-filter: blur(16px) saturate(1.3);\n  border-bottom: 1px solid var(--border);\n}\n.nav-inner {\n  display: flex; align-items: center; justify-content: space-between;\n  height: 68px;\n}\n.nav-links {\n  display: flex; gap: 28px; align-items: center;\n}\n.nav-links a {\n  font-size: 14px; font-weight: 500;\n  color: var(--text2);\n  transition: color .2s var(--ease);\n}\n.nav-links a:hover { color: var(--text1); }\n.nav-links a.current { color: var(--text1); font-weight: 600; }\n\n/* =========================================================================\n   Buttons\n   ========================================================================= */\n\n.btn {\n  display: inline-flex; align-items: center; gap: 8px;\n  font-family: var(--font); font-weight: 700;\n  font-size: 15px;\n  padding: 14px 28px;\n  border-radius: var(--r-pill);\n  border: 1px solid transparent;\n  white-space: nowrap;\n  transition: transform .22s var(--ease),\n              box-shadow .22s var(--ease),\n              border-color .22s var(--ease),\n              background .22s var(--ease),\n              color .22s var(--ease),\n              opacity .22s var(--ease);\n}\n\n.btn-primary {\n  background: var(--grad);\n  color: #fff;\n  box-shadow: var(--sh-brand-sm);\n  padding: 14px 32px;\n}\n.btn-primary:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 0 40px rgba(0,196,122,0.35);\n  opacity: 0.97;\n}\n\n.btn-ghost {\n  background: #fff;\n  color: var(--text2);\n  border: 1px solid var(--border-strong);\n}\n.btn-ghost:hover {\n  border-color: var(--green);\n  color: var(--text1);\n  box-shadow: 0 2px 12px rgba(0,196,122,0.12);\n}\n\n.btn-quiet {\n  color: var(--text2); padding: 10px 0;\n}\n.btn-quiet:hover { color: var(--text1); }\n\n.btn .arrow { transition: transform .2s var(--ease); }\n.btn:hover .arrow { transform: translateX(3px); }\n\n/* =========================================================================\n   Tag / Pill\n   ========================================================================= */\n\n.tag {\n  display: inline-flex; align-items: center; gap: 8px;\n  padding: 5px 14px;\n  border-radius: var(--r-pill);\n  font-size: 11px; font-weight: 700;\n  letter-spacing: 0.1em; text-transform: uppercase;\n  color: var(--green);\n  background: var(--green-bg);\n  border: 1px solid rgba(0,196,122,0.20);\n}\n.tag .dot {\n  width: 6px; height: 6px; border-radius: 50%;\n  background: var(--green); animation: pulse 2s infinite;\n}\n\n.tag-quiet {\n  display: inline-flex; align-items: center; gap: 8px;\n  padding: 5px 14px; border-radius: var(--r-pill);\n  font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;\n  color: var(--text3); background: var(--bg2); border: 1px solid var(--border);\n}\n\n.tag-dark {\n  display: inline-flex; align-items: center; gap: 8px;\n  padding: 5px 14px; border-radius: var(--r-pill);\n  font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;\n  color: rgba(255,255,255,0.6);\n  background: rgba(255,255,255,0.05);\n  border: 1px solid rgba(2