{
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "has": [{ "type": "host", "value": "app.vitaidsaude.com" }], "destination": "/app-v3/" },
    { "source": "/", "has": [{ "type": "host", "value": "medico.vitaidsaude.com" }], "destination": "/desktop/app-v2.html" },
    { "source": "/", "destination": "/site-oficial.html" },
    { "source": "/entrar", "destination": "/01-splash.html" },
    { "source": "/desktop", "destination": "/desktop/01-login.html" },
    { "source": "/desktop/", "destination": "/desktop/01-login.html" },
    { "source": "/desktop/legacy", "destination": "/desktop/app-legacy-2026-05-05.html" },
    { "source": "/desktop/legacy/(.*)", "destination": "/desktop/app-legacy-2026-05-05.html" }
  ],
  "headers": [
    {
      "source": "/site-oficial.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/desktop/app-v2.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/app-v3/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
