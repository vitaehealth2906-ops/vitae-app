# ============================================
# VITAE — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================

# ---- Banco de dados (Supabase PostgreSQL) ----
DATABASE_URL="postgresql://postgres:[SUA-SENHA]@db.[SEU-PROJETO].supabase.co:5432/postgres"

# ---- Supabase (Storage + Auth opcional) ----
SUPABASE_URL="https://[SEU-PROJETO].supabase.co"
SUPABASE_ANON_KEY="[SUA-ANON-KEY]"
SUPABASE_SERVICE_KEY="[SUA-SERVICE-KEY]"

# ---- JWT (gere uma string aleatória longa) ----
JWT_SECRET="trocar-por-uma-string-aleatoria-longa-e-segura"
JWT_REFRESH_SECRET="trocar-por-outra-string-aleatoria-diferente"
JWT_EXPIRES_IN="30d"
JWT_REFRESH_EXPIRES_IN="90d"

# ---- Anthropic (Claude API) ----
ANTHROPIC_API_KEY="sk-ant-..."

# ---- SMS (Twilio) ----
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1..."

# ---- OCR (Google Cloud Vision) ----
GOOGLE_CLOUD_CREDENTIALS="./google-credentials.json"

# ---- Email (Resend) ----
RESEND_API_KEY="re_..."

# ---- App ----
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
RESET_URL="https://vitaehealth2906-ops.github.io/vitae-app"

# ---- Padroes Observados v2 (apoio a decisao clinica multi-agente) ----
# Feature flag. Deixe em "false" ate validacao completa com medico betatester.
# Quando ativar ("true"), o pipeline v2 roda em paralelo ao summary antigo e
# enxerta cards rastreaveis de alerta farmacologico + diferenciais + red flags
# no summaryJson da pre-consulta. Frontend desktop renderiza automaticamente
# se campo presente. Se flag "false", sistema funciona exatamente como antes.
# Docs: docs/compliance/risk-analysis.md + data-flow.md + audit-trail-spec.md
PADROES_V2_ENABLED="false"

# ---- Modulo Agenda Medica (v1) ----
# Feature flag mestra. Deixe em "false" ate validacao do estagio dark launch.
# Quando "true", expoe rotas /agenda/* e renderiza sidebar item Agenda + Stats.
# Rollback de 60 segundos: setar "false" no Railway -> redeploy -> tudo escondido.
# Docs: docs/compliance/agenda-risk-analysis.md + agenda-data-flow.md + faq-agenda.md
AGENDA_V1_ENABLED="false"

# Sub-flag pra Google Calendar (read-only). Mantenha "false" enquanto setup OAuth nao concluido.
AGENDA_GCAL_ENABLED="false"

# Lista CSV de IDs de usuario habilitados em dark launch (estagio 1).
# Ex: AGENDA_DARK_USERS="user-id-1,user-id-2"
# Vazio = ninguem ve mesmo com flag mestra ON. Use em estagio 1.
AGENDA_DARK_USERS=""

# ---- Google Calendar OAuth (somente leitura) ----
# Lucas cria projeto no Google Cloud Console -> OAuth 2.0 Client ID -> Web Application
# Redirect URI em prod: https://vitae-app-production.up.railway.app/agenda/google/callback
# Redirect URI local: http://localhost:3001/agenda/google/callback
# Scope solicitado: https://www.googleapis.com/auth/calendar.readonly
GCAL_CLIENT_ID=""
GCAL_CLIENT_SECRET=""
GCAL_REDIRECT_URI="http://localhost:3001/agenda/google/callback"

# ---- Encriptacao do refresh_token Google (AES-256-GCM) ----
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 32 bytes Base64. Trocar = invalida todos os tokens Google ja salvos (medicos reconectam).
AGENDA_TOKEN_KEY=""

# ---- Push Web (VAPID) ----
# Gerar com: npx web-push generate-vapid-keys
# Chave publica vai pro frontend (api.js); privada fica so no backend.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:suporte@vitaehealth.com"

# ---- Sentry (observabilidade, opcional) ----
# Se vazio, sistema roda sem Sentry (no-op). Recomendado em prod.
SENTRY_DSN=""
